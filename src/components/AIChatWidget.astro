---
// src/components/AIChatWidget.astro
import SYSTEM_PROMPT_PT from '../content/ai-system-prompt.md?raw';
import SYSTEM_PROMPT_EN from '../content/ai-system-prompt-en.md?raw';
import ptJSON from '../i18n/pt.json';
import enJSON from '../i18n/en.json';
const SUGGESTIONS_PT = ptJSON['ai.suggestions'];
const SUGGESTIONS_EN = enJSON['ai.suggestions'];
---

<div class="ai-widget" id="aiWidget">
  <!-- ─── Painel de chat (expandido) ─── -->
  <div class="ai-chat-panel" id="aiChatPanel">
    <div class="ai-chat-panel-inner">

      <div class="ai-chat-header">
        <div class="ai-chat-title">
          <div class="ai-status-dot"></div>
          <span class="ai-name">Edu Agent</span>
          <span class="ai-sub" data-i18n="ai.sub">Portfólio Assistant</span>
        </div>
        <button class="ai-close-btn" id="aiModalClose" data-i18n-aria="ai.close.aria" aria-label="Fechar chat">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <div class="ai-messages" id="aiMessages">
        <div class="ai-msg ai-msg--bot">
          <div class="ai-avatar">ER</div>
          <div class="ai-bubble" data-i18n="ai.welcome">
            Olá! Sou o Edu Agent, a IA do portfólio do Eduardo Ritter. Posso te contar sobre sua trajetória, habilidades, projetos e muito mais. O que você gostaria de saber?
          </div>
        </div>
      </div>

      <div class="ai-typing" id="aiTyping" style="display:none">
        <div class="ai-avatar">ER</div>
        <div class="ai-typing-dots">
          <span></span><span></span><span></span>
        </div>
      </div>

      <div class="ai-chat-input-row">
        <input id="aiModalInput" type="text" class="ai-chat-input"
          placeholder="Digite sua mensagem..."
          data-i18n-placeholder="ai.input.placeholder"
          autocomplete="off" />
        <button class="ai-send-btn" id="aiModalSend"
          data-i18n-aria="ai.send.aria" aria-label="Enviar">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- ─── Hero input (colapsado) ─── -->
  <div class="ai-hero-box" id="aiHeroBox">
    <div class="ai-input-row" id="aiInputRow">
      <div class="ai-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C12 2 12 11.5 2 12C12 12.5 12 22 12 22C12 22 12 12.5 22 12C12 11.5 12 2 12 2Z"/>
          <path d="M19 2C19 2 19 6.5 15 7C19 7.5 19 12 19 12C19 12 19 7.5 23 7C19 6.5 19 2 19 2Z"/>
          <path d="M6 16C6 16 6 18.25 4 18.5C6 18.75 6 21 6 21C6 21 6 18.75 8 18.5C6 18.25 6 16 6 16Z"/>
        </svg>
      </div>
      <div class="ai-input-area" id="aiInputArea">
        <div class="ai-phrase-overlay" id="aiPhraseOverlay" aria-hidden="true">
          <span id="aiPhraseText" data-i18n="ai.phrase">Pergunte algo sobre o Eduardo...</span>
        </div>
        <input id="aiHeroInput" type="text" class="ai-hero-input" placeholder=""
          autocomplete="off"
          data-i18n-aria="ai.hero.aria" aria-label="Iniciar conversa com IA" />
      </div>
      <button id="aiHeroSend" class="ai-send-btn"
        data-i18n-aria="ai.send.aria" aria-label="Enviar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 6l6 6-6 6"/>
        </svg>
      </button>
    </div>
    <div class="ai-suggestions-wrapper">
      <!-- Gerado via JS em renderSuggestions() para suportar troca de idioma -->
      <div class="ai-suggestions" id="aiSuggestions"></div>
    </div>
  </div>
</div>

<style is:global>
  /* ─── Widget container ─── */
  .ai-widget {
    position: relative;
    width: 100%;
    max-width: 520px;
    border-radius: 16px;
    overflow: hidden;
    background: rgba(8, 8, 8, 0.92);
    border: 1px solid rgba(201, 169, 110, 0.2);
    box-shadow: 0 0 40px rgba(201, 169, 110, 0.06), 0 8px 32px rgba(0,0,0,0.4);
    transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease), border-radius 0.3s var(--ease);
    /* força GPU layer no mobile para evitar bug de composição que some o border/bg */
    transform: translateZ(0);
    -webkit-transform: translateZ(0);
    isolation: isolate;
  }

  .ai-widget:hover,
  .ai-widget:focus-within {
    border-color: rgba(201, 169, 110, 0.4);
    box-shadow: 0 0 60px rgba(201, 169, 110, 0.1), 0 8px 40px rgba(0,0,0,0.5);
  }

  .ai-widget.is-expanded {
    border-radius: 20px;
    border-color: rgba(201, 169, 110, 0.45);
    box-shadow: 0 0 80px rgba(201, 169, 110, 0.14), 0 16px 60px rgba(0,0,0,0.6);
  }



  /* ─── Chat panel: usa grid-template-rows para animar altura ─── */
  .ai-chat-panel {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-widget.is-expanded .ai-chat-panel {
    grid-template-rows: 1fr;
  }

  /* Filho único direto – obrigatório para o trick funcionar */
  .ai-chat-panel-inner {
    overflow: hidden;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  /* ─── Header ─── */
  .ai-chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(201, 169, 110, 0.12);
    background: linear-gradient(180deg, rgba(201, 169, 110, 0.06) 0%, rgba(201, 169, 110, 0) 100%);
    box-shadow: 0 4px 24px rgba(0,0,0,0.2) inset;
    flex-shrink: 0;
  }

  .ai-chat-title {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 10px rgba(74,222,128,0.6);
    animation: statusPulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes statusPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.7; transform: scale(0.85); }
  }

  .ai-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    color: #fcefd6;
    letter-spacing: -0.01em;
  }

  .ai-sub {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(201, 169, 110, 0.75);
    transition: color 0.3s ease;
  }

  .ai-status-dot.is-connecting {
    background: #facc15; /* amarelo */
    box-shadow: 0 0 10px rgba(250, 204, 21, 0.6);
    animation: statusPulseConnecting 1.5s ease-in-out infinite;
  }

  @keyframes statusPulseConnecting {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.6; transform: scale(0.9); }
  }

  .ai-close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    color: rgba(240, 237, 232, 0.55);
    flex-shrink: 0;
    transition: all 0.25s var(--ease);
  }

  .ai-close-btn:hover {
    background: rgba(201, 169, 110, 0.15);
    color: #fcefd6;
    border-color: rgba(201, 169, 110, 0.3);
    transform: rotate(90deg);
  }

  /* ─── Messages ─── */
  .ai-messages {
    height: 300px;
    overflow-y: auto;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    scroll-behavior: smooth;
    flex-shrink: 0;
  }

  .ai-messages::-webkit-scrollbar { width: 4px; }
  .ai-messages::-webkit-scrollbar-track { background: transparent; }
  .ai-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 2px; }

  .ai-msg {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    animation: msgIn 0.3s var(--ease);
  }

  @keyframes msgIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .ai-msg--user { 
    flex-direction: row-reverse; 
    align-self: flex-end;
  }

  .ai-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(201,169,110,0.3), rgba(201,169,110,0.1));
    border: 1px solid rgba(201,169,110,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--accent);
    flex-shrink: 0;
    font-family: var(--font-body);
  }

  .ai-msg--user .ai-avatar {
    background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.04));
    border-color: rgba(255,255,255,0.12);
    color: rgba(240,237,232,0.7);
  }

  .ai-bubble {
    max-width: 78%;
    padding: 11px 14px;
    border-radius: 14px;
    font-size: 0.86rem;
    line-height: 1.65;
    font-weight: 300;
  }

  .ai-msg--bot .ai-bubble {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    color: rgba(240,237,232,0.9);
    border-top-left-radius: 4px;
  }

  .ai-msg--user .ai-bubble {
    background: linear-gradient(135deg, rgba(201,169,110,0.2), rgba(201,169,110,0.1));
    border: 1px solid rgba(201,169,110,0.25);
    color: rgba(240,237,232,0.95);
    border-top-right-radius: 4px;
  }

  /* ─── Typing ─── */
  .ai-typing {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 18px 12px;
    flex-shrink: 0;
  }

  .ai-typing-dots {
    display: flex;
    gap: 5px;
    padding: 10px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    border-top-left-radius: 4px;
  }

  .ai-typing-dots span {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: rgba(201,169,110,0.5);
    animation: typingBounce 1.2s ease-in-out infinite;
  }

  .ai-typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .ai-typing-dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
    30%            { transform: translateY(-6px); opacity: 1; }
  }

  /* ─── Chat input row (inside expanded panel) ─── */
  .ai-chat-input-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 16px;
    border-top: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.01);
    flex-shrink: 0;
  }

  .ai-chat-input {
    flex: 1;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 10px 14px;
    color: #f0ede8;
    font-family: var(--font-body);
    font-size: 0.86rem;
    font-weight: 300;
    outline: none;
    caret-color: var(--accent);
    transition: border-color 0.25s;
  }

  .ai-chat-input::placeholder { color: rgba(240,237,232,0.25); }
  .ai-chat-input:focus { border-color: rgba(201,169,110,0.35); }

  /* ─── Send button (shared) ─── */
  .ai-send-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: var(--accent);
    border: none;
    color: #080808;
    flex-shrink: 0;
    transition: transform 0.2s var(--ease), background 0.2s, opacity 0.2s;
  }

  .ai-send-btn:hover    { transform: scale(1.06); background: #d4b67a; }
  .ai-send-btn:active   { transform: scale(0.95); }
  .ai-send-btn:disabled { opacity: 0.4; transform: none; }

  /* ─── Hero box (visível quando colapsado) ─── */
  .ai-hero-box {
    position: relative;
    z-index: 1;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    /* Animação de saída quando expande */
    max-height: 160px;
    overflow: hidden;
    opacity: 1;
    transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1),
                opacity 0.25s ease,
                padding 0.3s ease;
  }

  .ai-widget.is-expanded .ai-hero-box {
    max-height: 0;
    opacity: 0;
    padding-top: 0;
    padding-bottom: 0;
    pointer-events: none;
  }

  .ai-input-row {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 10px 12px;
    transition: border-color 0.25s;
  }

  .ai-widget:focus-within .ai-input-row { border-color: rgba(201,169,110,0.3); }

  .ai-icon { color: rgba(201,169,110,0.5); flex-shrink: 0; display: flex; }

  /* ─── Input area com frases animadas ─── */
  .ai-input-area {
    flex: 1;
    position: relative;
    height: 22px;
    overflow: hidden;
  }

  /* Overlay de frases que sobe ao focar */
  .ai-phrase-overlay {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    pointer-events: none;
    transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.28s ease;
    will-change: transform, opacity;
  }

  .ai-phrase-overlay span {
    color: rgba(240, 237, 232, 0.32);
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 300;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  /* Sobe o overlay quando o input está ativo */
  .ai-input-row.is-typing .ai-phrase-overlay {
    transform: translateY(-110%);
    opacity: 0;
  }

  .ai-hero-input {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: #f0ede8;
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 300;
    caret-color: var(--accent);
    opacity: 0;
    transition: opacity 0.25s ease 0.1s;
    padding: 0;
  }

  /* Aparece quando ativo */
  .ai-input-row.is-typing .ai-hero-input {
    opacity: 1;
  }

  .ai-hero-input::placeholder { color: rgba(240,237,232,0.3); }

  /* Hero send button smaller */
  .ai-hero-box .ai-send-btn { width: 36px; height: 36px; border-radius: 8px; }

  /* ─── Sugestões de perguntas (Carousel) ─── */
  .ai-suggestions-wrapper {
    overflow: hidden;
    position: relative;
    width: 100%;
    margin-top: 5px;
  }

  .ai-suggestions {
    display: flex;
    flex-direction: row;
    gap: 8px;
    width: max-content;
    animation: aiCarousel 300s linear infinite;
  }

  .ai-suggestions:hover,
  .ai-suggestions:active {
    animation-play-state: paused;
  }

  @keyframes aiCarousel {
    0%   { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 4px)); }
  }

  .ai-suggestion {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    text-align: center;
    color: rgba(240, 237, 232, 0.5);
    font-family: var(--font-body);
    font-size: 0.76rem;
    font-weight: 300;
    padding: 8px 14px;
    border-radius: 20px;
    line-height: 1.2;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }

  .ai-suggestion:hover {
    color: rgba(240, 237, 232, 0.9);
    background: rgba(255,255,255,0.05);
    border-color: rgba(201,169,110,0.3);
  }

  /* ─── Light mode ─── */
  [data-theme="light"] .ai-widget {
    background: rgba(250,249,247,0.97);
    border-color: rgba(201,169,110,0.25);
    box-shadow: 0 0 40px rgba(201,169,110,0.06), 0 8px 32px rgba(0,0,0,0.08);
  }
  [data-theme="light"] .ai-widget:hover,
  [data-theme="light"] .ai-widget:focus-within {
    box-shadow: 0 0 60px rgba(201,169,110,0.1), 0 8px 40px rgba(0,0,0,0.12);
  }
  [data-theme="light"] .ai-chat-header {
    background: linear-gradient(180deg, rgba(201,169,110,0.06) 0%, transparent 100%);
    border-bottom-color: rgba(201,169,110,0.12);
    box-shadow: none;
  }
  [data-theme="light"] .ai-name { color: var(--text-1); }
  [data-theme="light"] .ai-close-btn {
    background: rgba(0,0,0,0.03);
    border-color: rgba(0,0,0,0.08);
    color: rgba(13,12,10,0.45);
  }
  [data-theme="light"] .ai-close-btn:hover { background: rgba(201,169,110,0.12); color: var(--text-1); }
  [data-theme="light"] .ai-messages::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); }
  [data-theme="light"] .ai-msg--bot .ai-bubble {
    background: rgba(0,0,0,0.04);
    border-color: rgba(0,0,0,0.07);
    color: var(--text-1);
  }
  [data-theme="light"] .ai-msg--user .ai-bubble { color: var(--text-1); }
  [data-theme="light"] .ai-msg--user .ai-avatar {
    background: linear-gradient(135deg, rgba(201,169,110,0.15), rgba(201,169,110,0.05));
    border-color: rgba(201,169,110,0.2);
    color: var(--accent);
  }
  [data-theme="light"] .ai-typing-dots {
    background: rgba(0,0,0,0.04);
    border-color: rgba(0,0,0,0.07);
  }
  [data-theme="light"] .ai-chat-input-row {
    border-top-color: rgba(0,0,0,0.06);
    background: transparent;
  }
  [data-theme="light"] .ai-chat-input {
    background: rgba(0,0,0,0.04);
    border-color: rgba(0,0,0,0.08);
    color: var(--text-1);
  }
  [data-theme="light"] .ai-chat-input::placeholder { color: rgba(13,12,10,0.3); }
  [data-theme="light"] .ai-chat-input:focus { border-color: rgba(201,169,110,0.4); }
  [data-theme="light"] .ai-input-row { background: rgba(0,0,0,0.03); border-color: rgba(0,0,0,0.08); }
  [data-theme="light"] .ai-hero-input { color: var(--text-1); }
  [data-theme="light"] .ai-hero-input::placeholder { color: rgba(13,12,10,0.35); }
  [data-theme="light"] .ai-phrase-overlay span { color: rgba(13,12,10,0.38); }
  [data-theme="light"] .ai-suggestion {
    background: rgba(0,0,0,0.03);
    border-color: rgba(0,0,0,0.06);
    color: rgba(13,12,10,0.55);
  }
  [data-theme="light"] .ai-suggestion:hover {
    color: var(--text-1);
    background: rgba(0,0,0,0.05);
    border-color: rgba(201,169,110,0.3);
  }
  [data-theme="light"] .ai-binary-bg { color: rgba(201,169,110,0.1); }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .ai-messages { height: 250px; }

    /* Garante que o container renderiza corretamente em mobile */
    [data-theme="dark"] .ai-widget {
      background: rgba(8, 8, 8, 0.92) !important;
      border: 1px solid rgba(201, 169, 110, 0.2) !important;
      border-radius: 16px !important;
    }

    /* Garante que o input-row fica horizontal */
    .ai-input-row {
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      border-radius: 10px !important;
      padding: 10px 12px !important;
      flex-wrap: nowrap !important;
    }

    [data-theme="dark"] .ai-input-row {
      background: rgba(255,255,255,0.03) !important;
      border: 1px solid rgba(255,255,255,0.08) !important;
    }

    [data-theme="light"] .ai-input-row {
      background: rgba(0,0,0,0.03) !important;
      border: 1px solid rgba(0,0,0,0.08) !important;
    }

    .ai-hero-input {
      flex: 1 !important;
      min-width: 0 !important;
    }
  }
</style>

<script define:vars={{ SYSTEM_PROMPT_PT, SYSTEM_PROMPT_EN, SUGGESTIONS_PT, SUGGESTIONS_EN }}>
  (() => {
    const API_BASE = 'https://qwen-chat-478866638874.us-central1.run.app';
    const API_URL = `${API_BASE}/chat`;
    const HEALTH_URL = `${API_BASE}/health`;

    function getLang() {
      return document.documentElement.getAttribute('data-lang') || 'pt';
    }

    function getSystemPrompt() {
      return getLang() === 'en' ? SYSTEM_PROMPT_EN : SYSTEM_PROMPT_PT;
    }

    function getSuggestions() {
      return getLang() === 'en' ? SUGGESTIONS_EN : SUGGESTIONS_PT;
    }

    // ─── State e Conexão ───
    let chatHistory = [];
    let isLoading = false;
    let isApiReady = false;
    const STORAGE_KEY = 'eduAgentChatHistory';

    const widget       = document.getElementById('aiWidget');
    const heroInput    = document.getElementById('aiHeroInput');
    const heroSend     = document.getElementById('aiHeroSend');
    const chatInput    = document.getElementById('aiModalInput');
    const chatSend     = document.getElementById('aiModalSend');
    const messagesEl   = document.getElementById('aiMessages');
    const typingEl     = document.getElementById('aiTyping');
    const closeBtn     = document.getElementById('aiModalClose');
    const suggestionsEl = document.getElementById('aiSuggestions');

    // ─── Suggestions: render + re-render on lang change ───
    function renderSuggestions() {
      if (!suggestionsEl) return;
      const items = getSuggestions();
      const doubled = [...items, ...items]; // clone para scroll infinito
      suggestionsEl.innerHTML = doubled
        .map(msg => `<button class="ai-suggestion" data-msg="${msg.replace(/"/g, '&quot;')}">${msg}</button>`)
        .join('');
      suggestionsEl.querySelectorAll('.ai-suggestion').forEach(btn => {
        btn.addEventListener('click', () => openChat(btn.dataset.msg));
      });
    }

    // Observa mudança de data-lang no <html>
    new MutationObserver(() => renderSuggestions())
      .observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });



    // ─── Input Area e Overlay ───
    const inputRow    = document.getElementById('aiInputRow');
    const phraseOverlay = document.getElementById('aiPhraseOverlay');
    const phraseSpan  = document.getElementById('aiPhraseText');
    const inputArea   = document.getElementById('aiInputArea');
    function activateInput() {
      if (inputRow.classList.contains('is-typing')) return;
      inputRow.classList.add('is-typing');
      setTimeout(() => heroInput?.focus(), 50);
    }

    function deactivateInput() {
      if (heroInput?.value.trim()) return; // mantém ativo se tem texto
      inputRow.classList.remove('is-typing');
    }

    // Clicar em qualquer parte da row ativa o input
    inputRow?.addEventListener('click', activateInput);
    inputArea?.addEventListener('click', activateInput);
    heroInput?.addEventListener('blur', deactivateInput);

    // ─── Open ───
    function openChat(initialMsg) {
      widget.classList.add('is-expanded');
      setTimeout(() => chatInput?.focus(), 420);
      if (initialMsg?.trim()) setTimeout(() => sendMessage(initialMsg.trim()), 200);
    }

    // ─── Close ───
    function closeChat() {
      widget.classList.remove('is-expanded');
      inputRow.classList.remove('is-typing');
    }

    // ─── Append message ───
    function appendMessage(role, text) {
      const msg    = document.createElement('div');
      msg.className = `ai-msg ai-msg--${role === 'user' ? 'user' : 'bot'}`;

      const avatar = document.createElement('div');
      avatar.className = 'ai-avatar';
      avatar.textContent = role === 'user' ? 'VC' : 'ER';

      const bubble = document.createElement('div');
      bubble.className = 'ai-bubble';
      bubble.textContent = text;

      msg.appendChild(avatar);
      msg.appendChild(bubble);
      messagesEl.appendChild(msg);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function showTyping(show) {
      typingEl.style.display = show ? 'flex' : 'none';
      if (show) messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    // ─── Restore History ───
    function saveChat() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(chatHistory));
    }

    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      if (stored) {
        const parsed = JSON.parse(stored);
        if (Array.isArray(parsed) && parsed.length > 0) {
          chatHistory = parsed;
          chatHistory.forEach(msg => appendMessage(msg.role === 'user' ? 'user' : 'bot', msg.content));
        }
      }
    } catch (e) {
      console.warn('Erro ao restaurar histórico do chat:', e);
    }

    // ─── Health check ───
    const statusDot = document.querySelector('.ai-status-dot');
    const statusText = document.querySelector('.ai-sub');

    async function checkHealth() {
      // Atualiza painel interno (se houver)
      if (statusDot) statusDot.classList.add('is-connecting');
      if (statusText) statusText.textContent = getLang() === 'en' ? 'Connecting...' : 'Conectando...';

      // Atualiza o texto dentro do input box (Hero)
      if (!isApiReady) {
        if (phraseSpan) {
          phraseSpan.textContent = getLang() === 'en' ? 'Connecting to AI server...' : 'Conectando ao servidor de IA...';
          phraseSpan.style.color = '#facc15';
          phraseSpan.style.opacity = '1';
        }
      }

      try {
        const res = await fetch(HEALTH_URL);
        const data = await res.json();
        
        if (data.status === 'ok') {
          isApiReady = true;
          // Atualiza painel interno
          if (statusDot) statusDot.classList.remove('is-connecting');
          if (statusText) {
            statusText.textContent = getLang() === 'en' ? 'Portfolio Assistant' : 'Portfólio Assistant';
            statusText.style.color = 'rgba(74, 222, 128, 0.8)';
            setTimeout(() => { if (statusText) statusText.style.color = ''; }, 2000);
          }

          // Atualiza o texto visual do input
          phraseSpan.textContent = getLang() === 'en'
            ? 'Connected! Ask anything about Eduardo.'
            : 'Conectado! Pergunte qualquer coisa sobre o Eduardo.';
          phraseSpan.style.color = '#4ade80';

          return true;
        }
      } catch (err) {
        console.warn('API não está pronta:', err);
      }
      
      // Tenta de novo depois de 3 segundos se falhou
      setTimeout(checkHealth, 3000);
      return false;
    }

    // Inicia a checagem ao carregar
    checkHealth();

    // ─── Send ───
    async function sendMessage(text) {
      if (!text || isLoading) return;
      
      isLoading = true;
      chatSend.disabled = true;

      chatHistory.push({ role: 'user', content: text });
      saveChat();
      appendMessage('user', text);
      heroInput.value = '';
      chatInput.value = '';
      
      if (!isApiReady) {
        showTyping(true);
        setTimeout(() => {
          showTyping(false);
          appendMessage('bot', getLang() === 'en'
            ? 'Waiting for the server to stabilize... It may take a few seconds to start up for the first time today. I\'ll let you know when it\'s ready!'
            : 'Aguardando estabilizar conexão com o servidor... Ele pode levar alguns segundos para ligar a primeira vez hoje. Vou te avisar quando estiver pronto!');
          chatHistory.pop(); // tira a mensagem do usuário do history para ele tentar novamente
          saveChat();
          isLoading = false;
          chatSend.disabled = false;
        }, 800);
        return;
      }

      showTyping(true);

      try {
        const res = await fetch(API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            message: text,
            history: [{ role: 'system', content: getSystemPrompt() }, ...chatHistory.slice(0, -1)],
          }),
        });

        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data  = await res.json();
        const reply = data.resposta || (getLang() === 'en' ? 'Could not respond right now. Please try again.' : 'Não consegui responder agora. Tente novamente.');

        chatHistory.push({ role: 'assistant', content: reply });
        saveChat();
        showTyping(false);
        appendMessage('bot', reply);

      } catch (err) {
        console.error('AI Chat error:', err);
        showTyping(false);
        appendMessage('bot', getLang() === 'en' ? 'Oops! I had a connection issue. Please try again in a moment.' : 'Ops! Tive um problema de conexão. Tente novamente em instantes.');
        chatHistory.pop();
        saveChat();
      } finally {
        isLoading = false;
        chatSend.disabled = false;
        chatInput?.focus();
      }
    }

    // ─── Events ───
    heroInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && heroInput.value.trim()) openChat(heroInput.value.trim());
    });

    heroSend?.addEventListener('click', () => {
      const msg = heroInput?.value.trim();
      openChat(msg || null);
    });

    renderSuggestions();

    chatInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(chatInput.value.trim()); }
    });

    chatSend?.addEventListener('click', () => sendMessage(chatInput.value.trim()));

    closeBtn?.addEventListener('click', closeChat);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && widget?.classList.contains('is-expanded')) closeChat();
    });
  })();
</script>
