---
// src/components/Hero.astro
// ──────────────────────────
// Seção inicial com nome, tagline e CTA
---

<section id="hero" class="hero">
  <div class="container">
    <div class="hero-inner">

      <div class="hero-meta">
        <span class="label" data-i18n="hero.tag">Desenvolvedor &amp; Criativo</span>
        <span class="label">2026</span>
      </div>

      <h1 class="hero-headline">
        <span class="headline-line">Eduardo</span>
        <span class="headline-line">Ritter</span>
      </h1>

      <div class="hero-bottom">
        <div class="hero-content-block">
          <p class="hero-sub" data-i18n="hero.sub">
            Criando experiências digitais<br>modernas e impactantes.
          </p>
          <div class="hero-actions">
            <a href="#contact" class="btn-outline" data-i18n="hero.cta">Vamos Conversar</a>
          </div>
        </div>

        <div class="scroll-hint">
          <span class="label" data-i18n="hero.scroll">Rolar</span>
          <div class="scroll-line"><div class="scroll-line-inner"></div></div>
        </div>
      </div>

    </div>
  </div>
</section>
