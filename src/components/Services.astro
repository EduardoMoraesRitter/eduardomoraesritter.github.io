---
// src/components/Services.astro
// ──────────────────────────────
// Seção serviços — lista com hover + marquee de tecnologias
---

<section id="services" class="section reveal-section">
  <div class="container">

    <header class="section-header">
      <span class="section-index">03</span>
      <h2 data-i18n="services.title">Expertise</h2>
    </header>

    <!-- Lista de serviços -->
    <div class="services-list">

      <div class="service-item reveal-item" style="--delay: 0s">
        <span class="service-num label">01</span>
        <div class="service-content">
          <h3 data-i18n="services.item1.title">Engenharia de IA &amp; LLMs</h3>
          <p  data-i18n="services.item1.text">Soluções seguras e escaláveis usando RAG, Agentes e Modelos de Linguagem avançados.</p>
        </div>
        <span class="service-arrow" aria-hidden="true">↗</span>
      </div>

      <div class="service-item reveal-item" style="--delay: 0.08s">
        <span class="service-num label">02</span>
        <div class="service-content">
          <h3 data-i18n="services.item2.title">Arquitetura Cloud</h3>
          <p  data-i18n="services.item2.text">Design de sistemas distribuídos em GCP e AWS com foco em performance e custo.</p>
        </div>
        <span class="service-arrow" aria-hidden="true">↗</span>
      </div>

      <div class="service-item reveal-item" style="--delay: 0.16s">
        <span class="service-num label">03</span>
        <div class="service-content">
          <h3 data-i18n="services.item3.title">Data Science</h3>
          <p  data-i18n="services.item3.text">Modelagem preditiva, análise de dados e visão computacional aplicada a negócios.</p>
        </div>
        <span class="service-arrow" aria-hidden="true">↗</span>
      </div>

    </div>

    <!-- Marquee do stack de tecnologias -->
    <div class="stack-marquee">
      <div class="marquee-track" aria-hidden="true">
        <!-- Conjunto 1 -->
        <span>Python</span><span class="sep">·</span>
        <span>OpenAI</span><span class="sep">·</span>
        <span>Google Gemini</span><span class="sep">·</span>
        <span>LangChain</span><span class="sep">·</span>
        <span>Vertex AI</span><span class="sep">·</span>
        <span>RAG</span><span class="sep">·</span>
        <span>Vector DBs</span><span class="sep">·</span>
        <span>GCP</span><span class="sep">·</span>
        <span>AWS</span><span class="sep">·</span>
        <span>Golang</span><span class="sep">·</span>
        <span>Docker</span><span class="sep">·</span>
        <span>TensorFlow</span><span class="sep">·</span>
        <!-- Conjunto 2 (duplicado para loop contínuo) -->
        <span>Python</span><span class="sep">·</span>
        <span>OpenAI</span><span class="sep">·</span>
        <span>Google Gemini</span><span class="sep">·</span>
        <span>LangChain</span><span class="sep">·</span>
        <span>Vertex AI</span><span class="sep">·</span>
        <span>RAG</span><span class="sep">·</span>
        <span>Vector DBs</span><span class="sep">·</span>
        <span>GCP</span><span class="sep">·</span>
        <span>AWS</span><span class="sep">·</span>
        <span>Golang</span><span class="sep">·</span>
        <span>Docker</span><span class="sep">·</span>
        <span>TensorFlow</span><span class="sep">·</span>
      </div>
    </div>

  </div>
</section>
