---
// src/components/Services.astro
// ──────────────────────────────
// Seção serviços — lista com hover + marquee de tecnologias
---

<section id="services" class="section reveal-section">
  <div class="container">

    <header class="section-header">
      <span class="section-index">02</span>
      <h2 data-i18n="services.title">Serviços</h2>
    </header>

    <!-- Lista de serviços -->
    <div class="services-list">

      <div class="service-item reveal-item" style="--delay: 0s">
        <span class="service-num label">01</span>
        <div class="service-content">
          <h3 data-i18n="services.item1.title">Design &amp; UI</h3>
          <p  data-i18n="services.item1.text">Interfaces modernas, responsivas e com atenção precisa aos detalhes visuais.</p>
        </div>
        <span class="service-arrow" aria-hidden="true">↗</span>
      </div>

      <div class="service-item reveal-item" style="--delay: 0.08s">
        <span class="service-num label">02</span>
        <div class="service-content">
          <h3 data-i18n="services.item2.title">Desenvolvimento</h3>
          <p  data-i18n="services.item2.text">HTML5, CSS3, JavaScript — código limpo, performático e bem estruturado.</p>
        </div>
        <span class="service-arrow" aria-hidden="true">↗</span>
      </div>

      <div class="service-item reveal-item" style="--delay: 0.16s">
        <span class="service-num label">03</span>
        <div class="service-content">
          <h3 data-i18n="services.item3.title">Soluções Digitais</h3>
          <p  data-i18n="services.item3.text">Tecnologia eficiente focada em resolver problemas reais com precisão.</p>
        </div>
        <span class="service-arrow" aria-hidden="true">↗</span>
      </div>

    </div>

    <!-- Marquee do stack de tecnologias -->
    <div class="stack-marquee">
      <div class="marquee-track" aria-hidden="true">
        <!-- Conjunto 1 -->
        <span>HTML5</span><span class="sep">·</span>
        <span>CSS3</span><span class="sep">·</span>
        <span>JavaScript</span><span class="sep">·</span>
        <span>TypeScript</span><span class="sep">·</span>
        <span>React</span><span class="sep">·</span>
        <span>Figma</span><span class="sep">·</span>
        <span>Git</span><span class="sep">·</span>
        <span>Node.js</span><span class="sep">·</span>
        <span>Tailwind</span><span class="sep">·</span>
        <span>Next.js</span><span class="sep">·</span>
        <span>Astro</span><span class="sep">·</span>
        <span>Vite</span><span class="sep">·</span>
        <!-- Conjunto 2 (duplicado para loop contínuo) -->
        <span>HTML5</span><span class="sep">·</span>
        <span>CSS3</span><span class="sep">·</span>
        <span>JavaScript</span><span class="sep">·</span>
        <span>TypeScript</span><span class="sep">·</span>
        <span>React</span><span class="sep">·</span>
        <span>Figma</span><span class="sep">·</span>
        <span>Git</span><span class="sep">·</span>
        <span>Node.js</span><span class="sep">·</span>
        <span>Tailwind</span><span class="sep">·</span>
        <span>Next.js</span><span class="sep">·</span>
        <span>Astro</span><span class="sep">·</span>
        <span>Vite</span><span class="sep">·</span>
      </div>
    </div>

  </div>
</section>
