---
// src/components/Architecture.astro
---

<section id="architecture" class="arch-section reveal-section">
  <div class="container">

    <header class="section-header">
      <span class="section-index">01</span>
      <h2 class="arch-title" data-i18n="arch.title">Arquitetura Conversacional</h2>
    </header>

    <p class="arch-tagline reveal" data-i18n="arch.tagline">Projetando o futuro com IA Generativa e arquiteturas escaláveis.</p>
    <div class="arch-wrapper reveal">
      <svg id="archSvg" viewBox="0 0 960 590" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">

        <defs>
          <!-- Arrow markers -->
          <marker id="a-or" markerWidth="7" markerHeight="7" refX="5" refY="3" orient="auto"><path d="M0,0 L0,6 L7,3z" fill="#e8960a"/></marker>
          <marker id="a-bl" markerWidth="7" markerHeight="7" refX="5" refY="3" orient="auto"><path d="M0,0 L0,6 L7,3z" fill="#5bbfef"/></marker>
          <marker id="a-gy" markerWidth="7" markerHeight="7" refX="5" refY="3" orient="auto"><path d="M0,0 L0,6 L7,3z" fill="#555"/></marker>
          <marker id="a-gr" markerWidth="7" markerHeight="7" refX="5" refY="3" orient="auto"><path d="M0,0 L0,6 L7,3z" fill="#4ade80"/></marker>
          <marker id="a-ev" markerWidth="7" markerHeight="7" refX="5" refY="3" orient="auto"><path d="M0,0 L0,6 L7,3z" fill="#a3cfff"/></marker>
          <marker id="a-or-rev" markerWidth="7" markerHeight="7" refX="2" refY="3" orient="auto"><path d="M7,0 L7,6 L0,3z" fill="#e8960a"/></marker>
        </defs>

        <g transform="translate(60, 0)">
        <!-- ══ CONNECTIONS ══ -->��═ -->
        <path class="flow-or-req" d="M 154 222 L 455 222" stroke="#e8960a" stroke-width="1.2" stroke-dasharray="5,4" fill="none" marker-end="url(#a-or)"/>
        <text x="230" y="211" class="elbl or">Request</text>
        <text x="430" y="211" class="elbl or">Process</text>

        <path class="flow-gr-resp" d="M 455 245 L 154 245" stroke="#4ade80" stroke-width="1.2" stroke-dasharray="5,4" fill="none" marker-end="url(#a-gr)"/>
        <text x="310" y="254" class="elbl gr" style="font-size:7.5px">5. Response</text>

        <path class="flow-bl" d="M 585 190 C 610 190 610 60 633 60" stroke="#5bbfef" stroke-width="1.2" stroke-dasharray="5,4" fill="none" marker-end="url(#a-bl)"/>
        <text x="610" y="110" class="elbl bl">3. Retrieve</text>

        <line class="flow-bl" x1="585" y1="224" x2="633" y2="224" stroke="#5bbfef" stroke-width="1.2" stroke-dasharray="5,4" marker-end="url(#a-bl)"/>
        <text x="610" y="215" class="elbl bl">4. Execute</text>

        <path class="flow-bl" d="M 585 245 C 610 245 610 380 633 380" stroke="#5bbfef" stroke-width="1.2" stroke-dasharray="5,4" fill="none" marker-end="url(#a-bl)"/>

        <path class="flow-gy" d="M 305 260 C 305 380 340 380 340 440" stroke="#555" stroke-width="1.2" stroke-dasharray="4,4" fill="none" marker-end="url(#a-gy)"/>
        <text x="290" y="360" class="elbl gy">Logs</text>

        <path class="flow-gy" d="M 520 289 C 520 380 430 380 430 440" stroke="#555" stroke-width="1.2" stroke-dasharray="4,4" fill="none" marker-end="url(#a-gy)"/>
        <text x="480" y="350" class="elbl gy">Metrics & Monitor</text>

        <path class="flow-ev" d="M 460 490 C 580 490 610 380 633 380" stroke="#a3cfff" stroke-width="1.2" stroke-dasharray="5,3" fill="none" marker-end="url(#a-ev)"/>
        <text x="540" y="460" class="elbl ev">Prompt Evolution</text>

        <!-- ══ TUNNEL PIPE ══ -->
        <g id="tunnelNode" class="tunnel-node" style="cursor:pointer">
          <ellipse cx="205" cy="227.5" rx="8" ry="32.5" fill="#0d0d0d" stroke="rgba(255,255,255,0.20)" stroke-width="1.5" />
          <path d="M 405 195 A 8 32.5 0 0 1 405 260" fill="none" stroke="rgba(255,255,255,0.20)" stroke-width="1.5"/>
          <line x1="205" y1="195" x2="405" y2="195" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="4,4"/>
          <line x1="205" y1="260" x2="405" y2="260" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="4,4"/>
          <rect class="tunnel-nbg" x="205" y="195" width="200" height="65" fill="rgba(255,255,255,0.01)" stroke="none" style="transition:fill 0.2s"/>

          <text x="305" y="208" class="tunnel-main-lbl" style="font-size: 10px;">Queue</text>
          <text x="395" y="210" class="nplus">+</text>
        </g>

        <!-- ══ NODE: Channels ══ -->
        <g class="arch-node" data-node="channels" transform="translate(10, 199)">
          <rect class="nbg" width="144" height="50" rx="5"/>
          <rect x="8" y="10" width="22" height="15" rx="3" fill="none" stroke="#666" stroke-width="1.2"/>
          <circle cx="14" cy="17.5" r="1.5" fill="#666"/>
          <circle cx="19" cy="17.5" r="1.5" fill="#666"/>
          <circle cx="24" cy="17.5" r="1.5" fill="#666"/>
          <path d="M11,25 L10,30 L16,25" fill="none" stroke="#666" stroke-width="1.1" stroke-linejoin="round"/>
          <text class="ntitle" x="36" y="27">Channels</text>
          <text class="nplus" x="132" y="27">+</text>
        </g>

        <!-- ══ NODE: AI Engine ══ -->
        <g class="arch-node node-ai" data-node="ai" transform="translate(455, 159)">
          <circle class="ai-pulse-ring" cx="65" cy="65" r="40" fill="none" stroke="rgba(232,150,10,0.12)" stroke-width="1"/>
          <rect class="nbg nbg-ai" width="130" height="130" rx="6"/>
          <circle cx="35" cy="40" r="4.5" fill="none" stroke="#e8960a" stroke-width="1.2" opacity="0.9"/>
          <circle cx="35" cy="70" r="4.5" fill="none" stroke="#e8960a" stroke-width="1.2" opacity="0.9"/>
          <circle cx="65" cy="30" r="4.5" fill="none" stroke="#888" stroke-width="1.2"/>
          <circle cx="65" cy="55" r="4.5" fill="none" stroke="#999" stroke-width="1.2"/>
          <circle cx="65" cy="80" r="4.5" fill="none" stroke="#888" stroke-width="1.2"/>
          <circle cx="95" cy="55" r="4.5" fill="none" stroke="#5bbfef" stroke-width="1.2" opacity="0.9"/>
          <line x1="39.5" y1="40" x2="60.5" y2="30" stroke="#444" stroke-width="1"/>
          <line x1="39.5" y1="40" x2="60.5" y2="55" stroke="#444" stroke-width="1"/>
          <line x1="39.5" y1="40" x2="60.5" y2="80" stroke="#444" stroke-width="1"/>
          <line x1="39.5" y1="70" x2="60.5" y2="30" stroke="#444" stroke-width="1"/>
          <line x1="39.5" y1="70" x2="60.5" y2="55" stroke="#444" stroke-width="1"/>
          <line x1="39.5" y1="70" x2="60.5" y2="80" stroke="#444" stroke-width="1"/>
          <line x1="69.5" y1="30" x2="90.5" y2="55" stroke="#444" stroke-width="1"/>
          <line x1="69.5" y1="55" x2="90.5" y2="55" stroke="#444" stroke-width="1"/>
          <line x1="69.5" y1="80" x2="90.5" y2="55" stroke="#444" stroke-width="1"/>
          <text class="ntitle ntitle-ai" x="65" y="108" text-anchor="middle">AI Engine</text>
          <text class="nplus" x="110" y="112">+</text>
        </g>

        <!-- ══ NODE: Knowledge Base ══ -->
        <g class="arch-node" data-node="base" transform="translate(635, 25)">
          <path class="nbg" d="M 0 15 L 0 75 A 77.5 15 0 0 0 155 75 L 155 15 Z"/>
          <ellipse class="cyl-lid" cx="77.5" cy="15" rx="77.5" ry="15"/>
          <text class="ntitle" x="77.5" y="48" text-anchor="middle">Knowledge Base</text>
          <text class="nplus" x="140" y="48">+</text>
        </g>

        <!-- ══ NODE: Tools ══ -->
        <g class="arch-node" data-node="tools" transform="translate(635, 199)">
          <path class="nbg" d="M 12 0 L 143 0 L 155 25 L 143 50 L 12 50 L 0 25 Z" />
          <rect x="18" y="18" width="14" height="14" rx="2" fill="none" stroke="#666" stroke-width="1.2"/>
          <path d="M21 18 V 14 M25 18 V 14 M29 18 V 14" stroke="#666" stroke-width="1.2"/>
          <path d="M21 32 V 36 M25 32 V 36 M29 32 V 36" stroke="#666" stroke-width="1.2"/>
          <path d="M32 21 H 36 M32 25 H 36 M32 29 H 36" stroke="#666" stroke-width="1.2"/>
          <circle cx="25" cy="25" r="2" fill="#555" />
          <text class="ntitle" x="50" y="27">Tools</text>
          <text class="nplus" x="132" y="27">+</text>
        </g>

        <!-- ══ NODE: Prompts ══ -->
        <g class="arch-node" data-node="prompts" transform="translate(635, 330)">
          <rect x="6" y="-6" width="70" height="100" rx="3" fill="#0d0d0d" stroke="rgba(255,255,255,0.08)" stroke-width="1" opacity="0.4" />
          <rect x="3" y="-3" width="70" height="100" rx="3" fill="#0d0d0d" stroke="rgba(255,255,255,0.12)" stroke-width="1" opacity="0.7" />
          <path class="nbg" d="M 0 3 Q 0 0 3 0 L 55 0 L 70 15 L 70 97 Q 70 100 67 100 L 3 100 Q 0 100 0 97 Z" />
          <path class="doc-fold" d="M 55 0 L 55 15 L 70 15" fill="none" stroke="var(--border)" stroke-width="1" style="transition: stroke 0.2s"/>
          <text class="ntitle" x="35" y="55" text-anchor="middle">Prompts</text>
          <text class="nplus" x="60" y="90">+</text>
        </g>

        <!-- ══ NODE: Monitoring ══ -->
        <g class="arch-node" data-node="monitoring" transform="translate(280, 420)">
          <path class="nbg" d="M 0 6 Q 0 0 6 0 L 174 0 Q 180 0 180 6 L 180 114 Q 180 120 174 120 L 6 120 Q 0 120 0 114 Z"/>
          <path d="M 0 22 L 180 22" class="monitor-bar" stroke="var(--border)" stroke-width="1" opacity="0.4" />
          <circle cx="12" cy="11" r="2.5" fill="#ff5f56" opacity="0.9"/>
          <circle cx="21" cy="11" r="2.5" fill="#ffbd2e" opacity="0.9"/>
          <circle cx="30" cy="11" r="2.5" fill="#27c93f" opacity="0.9"/>
          <text x="90" y="13" text-anchor="middle" style="font-size:8px; letter-spacing: 0.12em; text-transform: uppercase; fill: #666; font-weight: 500;">Observability</text>
          <circle cx="168" cy="11" r="1.8" fill="#27c93f"><animate attributeName="opacity" values="1;0.2;1" dur="2s" repeatCount="indefinite"/></circle>
          <g transform="translate(8, 30)">
            <rect width="52" height="20" rx="2" fill="rgba(0,0,0,0.4)" stroke="rgba(255,255,255,0.05)"/>
            <text x="4" y="8" style="font-size:5px; fill:#666; text-transform:uppercase;">Latência</text>
            <text x="4" y="16" style="font-size:7px; fill:#e8960a; font-weight:600;">24ms</text>
            <rect x="56" width="52" height="20" rx="2" fill="rgba(0,0,0,0.4)" stroke="rgba(255,255,255,0.05)"/>
            <text x="60" y="8" style="font-size:5px; fill:#666; text-transform:uppercase;">Token/s</text>
            <text x="60" y="16" style="font-size:7px; fill:#4ade80; font-weight:600;">85.2</text>
            <rect x="112" width="52" height="20" rx="2" fill="rgba(0,0,0,0.4)" stroke="rgba(255,255,255,0.05)"/>
            <text x="116" y="8" style="font-size:5px; fill:#666; text-transform:uppercase;">Sucesso</text>
            <text x="116" y="16" style="font-size:7px; fill:#5bbfef; font-weight:600;">99.9%</text>
          </g>
          <g transform="translate(8, 56)">
             <rect width="164" height="54" rx="3" fill="rgba(0,0,0,0.6)" stroke="rgba(255,255,255,0.03)" />
             <line x1="0" y1="18" x2="164" y2="18" stroke="rgba(255,255,255,0.02)" stroke-width="0.5" />
             <line x1="0" y1="36" x2="164" y2="36" stroke="rgba(255,255,255,0.02)" stroke-width="0.5" />
             <polyline points="5,45 15,40 30,48 45,35 60,42 75,25 90,40 105,15 120,45 135,38 150,48 160,42" fill="none" stroke="#e8960a" stroke-width="1.2" stroke-linejoin="round" />
          </g>
          <text class="nplus" x="160" y="108">+</text>
        </g>
        </g>
      </svg>

      <!-- ══ DYNAMIC MODAL ══ -->
      <div id="archModal" class="tunnel-modal" aria-hidden="true">
        <button class="tmodal-close" id="archModalClose">&times;</button>
        <div class="tmodal-inner">
          <div class="tmodal-icon" id="archModalIcon">⌁</div>
          <div class="tmodal-content">
            <h4 class="tmodal-title" id="archModalTitle">Título</h4>
            <p class="tmodal-desc" id="archModalDesc">Descrição</p>
            <div class="tmodal-tags" id="archModalTags"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.arch-section { 
  padding: 8rem 0 6rem;
}

.arch-section .container {
  max-width: 1300px;
}

.arch-tagline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    font-weight: 300;
    color: var(--text-2);
    line-height: 1.6;
    max-width: 800px;
    margin-bottom: 5rem;
}

.arch-title {
  font-family: var(--font-display);
  font-size: clamp(1.9rem, 3.5vw, 3rem);
  font-weight: 300;
  color: var(--text-1);
  margin: 0;
  line-height: 1.1;
  letter-spacing: -0.02em;
}

.arch-wrapper { 
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}
#archSvg { 
  display: block; 
  width: 100%; 
  max-width: 1100px;
  height: auto; 
}

/* ── ANIMATIONS ── */
@keyframes flow-dash { to { stroke-dashoffset: -18; } }
.flow-or-req, .flow-gr-resp, .flow-bl, .flow-gy, .flow-ev { animation: flow-dash 2s linear infinite; }

/* AI Engine pulse ring */
@keyframes pulse-ring {
  0%   { r: 35; opacity: 0.2; }
  70%  { r: 55; opacity: 0; }
  100% { r: 55; opacity: 0; }
}
.ai-pulse-ring { animation: pulse-ring 2.5s ease-out infinite; transform-origin: center; transform-box: fill-box; }

/* Base node styling */
.arch-node { cursor: pointer; }
.nbg {
  fill: var(--bg);
  stroke: var(--border);
  stroke-width: 1;
  transition: stroke 0.2s, filter 0.2s;
}
.nbg-ai { fill: #0d0d0d; stroke: rgba(255,255,255,0.1); }
.cyl-lid { fill: #111; stroke: var(--border); stroke-width: 1; transition: stroke 0.2s, fill 0.2s; }
.doc-fold { fill: none; stroke: var(--border); stroke-width: 1; transition: stroke 0.2s; }

.arch-node:hover .nbg, .arch-node:hover .cyl-lid, .arch-node:hover .doc-fold { stroke: var(--border-hover); }
.arch-node.open .nbg, .arch-node.open .cyl-lid, .arch-node.open .doc-fold {
  stroke: var(--accent);
  filter: drop-shadow(0 0 8px rgba(201,169,110,0.15));
}

/* Light mode overrides */
[data-theme="light"] .cyl-lid { fill: #2a2a2a; }
[data-theme="light"] .tunnel-main-lbl { fill: rgba(0,0,0,0.35); }
[data-theme="light"] .elbl.gy { fill: #666; }

.ntitle {
  font-size: 11px;
  fill: var(--text-1);
  font-family: var(--font-body);
  font-weight: 500;
  dominant-baseline: middle;
  pointer-events: none;
}
.ntitle-ai { fill: #fff; font-size: 11px; }
.nplus {
  font-size: 15px;
  fill: var(--text-2);
  font-family: var(--font-body);
  dominant-baseline: middle;
  transition: fill 0.2s;
  pointer-events: none;
}
.tunnel-main-lbl { font-size: 11px; fill: rgba(255,255,255,0.3); font-family: var(--font-body); text-anchor: middle; font-weight: 500; }
.elbl { font-size: 8px; font-family: var(--font-body); text-anchor: middle; pointer-events: none; }
.elbl.or { fill: #e8960a; }
.elbl.bl { fill: #5bbfef; }
.elbl.gy { fill: #888; }
.elbl.ev { fill: #a3cfff; }
.elbl.gr { fill: #4ade80; }

/* Modal */
.tunnel-modal {
  position: absolute;
  top: 35%;
  left: 50%;
  transform: translate(-50%, 0) scale(0.96);
  width: min(480px, 90%);
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.5rem;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s var(--ease);
  z-index: 100;
  box-shadow: 0 24px 64px rgba(0,0,0,0.6);
}
.tunnel-modal.open { opacity: 1; pointer-events: auto; transform: translate(-50%, 0) scale(1); }
.tmodal-close { position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: var(--text-3); font-size: 1.6rem; cursor: pointer; }
.tmodal-inner { display: flex; gap: 1.5rem; }
.tmodal-icon { font-size: 2.2rem; opacity: 0.3; }
.tmodal-title { font-family: var(--font-display); font-size: 1.5rem; color: var(--text-1); margin-bottom: 0.5rem; }
.tmodal-desc { font-size: 0.85rem; color: var(--text-2); line-height: 1.7; margin-bottom: 1.2rem; }
.tmodal-tag { border: 1px solid var(--border); background: var(--bg-elevated); padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.7rem; color: var(--text-2); margin: 0 4px 4px 0; display: inline-block; }
</style>

<script>
  const nodeData = {
    'tunnel': { icon: '⌁', title: 'Túnel de Comunicação', desc: 'Camada responsável por <strong>receber, validar e enfileirar</strong> mensagens.', tags: ['API Gateway', 'SQS', 'Rate Limit'] },
    'channels': { icon: '💬', title: 'Channels', desc: 'Entrada unificada para WhatsApp, Instagram, Webchat.', tags: ['WhatsApp', 'Omnichannel'] },
    'ai': { icon: '🧠', title: 'AI Engine', desc: 'O núcleo de inteligência da arquitetura.', tags: ['LLM', 'Claude 3.5'] },
    'base': { icon: '📚', title: 'Knowledge Base', desc: 'Busca semântica via RAG.', tags: ['Vector DB', 'Pinecone'] },
    'tools': { icon: '🔧', title: 'Tools', desc: 'Habilidades e conexões externas.', tags: ['APIs', 'Functions'] },
    'prompts': { icon: '📝', title: 'Prompts', desc: 'Templates e System Prompts otimizados.', tags: ['Prompt Eng.', 'Persona'] },
    'monitoring': { icon: '👁️', title: 'Monitoring', desc: 'Observabilidade completa em tempo real.', tags: ['Logs', 'Metrics'] }
  };

  const archModal = document.getElementById('archModal');
  const archModalClose = document.getElementById('archModalClose');
  const archModalIcon = document.getElementById('archModalIcon');
  const archModalTitle = document.getElementById('archModalTitle');
  const archModalDesc = document.getElementById('archModalDesc');
  const archModalTags = document.getElementById('archModalTags');

  let activeNode = null;

  function closeModal() {
    archModal.classList.remove('open');
    if (activeNode) {
      activeNode.classList.remove('open');
      activeNode.classList.remove('active');
      const pl = activeNode.querySelector('.nplus');
      if (pl) pl.textContent = '+';
      activeNode = null;
    }
  }

  function openModal(key, el) {
    const data = nodeData[key];
    if (!data) return;
    archModalIcon.textContent = data.icon;
    archModalTitle.textContent = data.title;
    archModalDesc.innerHTML = data.desc;
    archModalTags.innerHTML = data.tags.map(t => `<span class="tmodal-tag">${t}</span>`).join('');
    archModal.classList.add('open');
    activeNode = el;
    if (activeNode.classList.contains('arch-node')) activeNode.classList.add('open');
    if (activeNode.id === 'tunnelNode') activeNode.classList.add('active');
    const pl = el.querySelector('.nplus');
    if (pl) pl.textContent = '×';
  }

  document.querySelectorAll('.arch-node').forEach(node => {
    node.addEventListener('click', e => {
      e.stopPropagation();
      openModal(node.dataset.node, node);
    });
  });

  document.getElementById('tunnelNode').addEventListener('click', e => {
    e.stopPropagation();
    openModal('tunnel', e.currentTarget);
  });

  archModalClose.addEventListener('click', closeModal);
  const archSvg = document.getElementById('archSvg');
  if (archSvg) archSvg.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
