---
// src/components/Experience.astro
// ────────────────────────────────
// Seção de Experiência — Timeline premium
---

<section id="experience" class="section reveal-section">
  <div class="container">

    <header class="section-header">
      <span class="section-index">03</span>
      <h2 data-i18n="experience.title">Últimas Jornadas</h2>
    </header>

    <div class="experience-list">

      <!-- Job 1 -->
      <div class="experience-item reveal-item" style="--delay: 0s">
        <div class="exp-dot"></div>
        <div class="exp-header">
          <h3 data-i18n="experience.job1.title">Staff AI Engineer @ Contabilizei</h3>
          <span class="exp-date label" data-i18n="experience.job1.date">2024 — Presente</span>
        </div>
        <p class="exp-desc" data-i18n="experience.job1.desc">
          Liderando a automação de onboarding e vendas com IA Generativa, alcançando +70% de conversão e reduzindo drasticamente operações manuais.
        </p>
      </div>

      <!-- Job 2 -->
      <div class="experience-item reveal-item" style="--delay: 0.1s">
        <div class="exp-dot"></div>
        <div class="exp-header">
          <h3 data-i18n="experience.job2.title">Head of AI @ BrandLovrs</h3>
          <span class="exp-date label" data-i18n="experience.job2.date">2023 — 2024</span>
        </div>
        <p class="exp-desc" data-i18n="experience.job2.desc">
          Arquitetei sistemas de recomendação baseados em LLM e analytics, tornando a IA o core da infraestrutura da empresa.
        </p>
      </div>

      <!-- Job 3 -->
      <div class="experience-item reveal-item" style="--delay: 0.2s">
        <div class="exp-dot"></div>
        <div class="exp-header">
          <h3 data-i18n="experience.job3.title">Senior Data Scientist @ XP Inc.</h3>
          <span class="exp-date label" data-i18n="experience.job3.date">2021 — 2023</span>
        </div>
        <p class="exp-desc" data-i18n="experience.job3.desc">
          Desenvolvi modelos de ML e chatbots para milhões de usuários, integrando soluções via WhatsApp e Alexa para reduzir suporte humano em 25%.
        </p>
      </div>

    </div>

    <!-- Link para o currículo completo -->
    <div class="exp-footer reveal-item" style="--delay: 0.3s">
      <a href="/assets/docs/Ritter_Resume.pdf" target="_blank" class="btn-outline">
        <span data-i18n="experience.cv">Ver Currículo Completo (PDF)</span>
      </a>
    </div>

  </div>
</section>

<style>
  .experience-list {
    position: relative;
    padding-left: 32px;
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .experience-list::before {
    content: '';
    position: absolute;
    left: 4px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--border);
  }

  .experience-item {
    position: relative;
  }

  .exp-dot {
    position: absolute;
    left: -32px;
    top: 8px;
    width: 9px;
    height: 9px;
    background: var(--text-1);
    border-radius: 50%;
    transform: translateX(-50%);
    box-shadow: 0 0 0 4px var(--bg);
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .exp-header h3 {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.2vw, 1.8rem);
    font-weight: 400;
    color: var(--text-1);
    letter-spacing: -0.01em;
  }

  .exp-date {
    color: var(--text-3);
  }

  .exp-desc {
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--text-2);
    line-height: 1.7;
    max-width: 700px;
  }

  .exp-footer {
    margin-top: 80px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .exp-header {
      flex-direction: column;
      gap: 4px;
    }
  }
</style>
