---
// src/components/Nav.astro
// ─────────────────────────
// Cabeçalho fixo com navegação, toggle de idioma e tema
---

<header id="header">
  <nav class="nav">

    <a href="#hero" class="nav-logo">ER</a>

    <ul class="nav-links" id="navLinks">
      <li><a href="#hero"       data-i18n="nav.home">Início</a></li>
      <li><a href="#about"      data-i18n="nav.about">Sobre</a></li>
      <li><a href="#experience" data-i18n="nav.services">Jornada</a></li>
      <li><a href="#recognition" data-i18n="nav.recognition">Impacto</a></li>
      <li><a href="#services"   data-i18n="nav.expertise">Expertise</a></li>
      <li><a href="#contact"    data-i18n="nav.contact">Contato</a></li>
    </ul>

    <div class="nav-controls">
      <button class="btn-control btn-lang" id="langToggle" aria-label="Toggle language">
        <span id="langLabel">EN</span>
      </button>
      <button class="btn-control btn-theme" id="themeToggle" aria-label="Toggle theme">
        <!-- Sol: visível no modo escuro -->
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <circle cx="12" cy="12" r="4.5"/>
          <line x1="12" y1="2"    x2="12" y2="5"/>
          <line x1="12" y1="19"   x2="12" y2="22"/>
          <line x1="4.22" y1="4.22"   x2="6.34" y2="6.34"/>
          <line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/>
          <line x1="2"  y1="12"  x2="5"  y2="12"/>
          <line x1="19" y1="12"  x2="22" y2="12"/>
          <line x1="4.22" y1="19.78"  x2="6.34" y2="17.66"/>
          <line x1="17.66" y1="6.34"  x2="19.78" y2="4.22"/>
        </svg>
        <!-- Lua: visível no modo claro -->
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>

    <button class="nav-hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span>
    </button>

  </nav>
</header>
